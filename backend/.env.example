# Cấu hình SMTP Gmail gửi thư cho chức năng Quên mật khẩu & Database Connection
# Tuyệt đối KHÔNG commit file .env thật chứa thông tin bảo mật lên Git!

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/Travel_app

# Email gửi thư (ví dụ: saigontravid@gmail.com)
SMTP_EMAIL=

# Mật khẩu ứng dụng của Google (App Password)
SMTP_APP_PASSWORD=
